generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  ACTIVE
  INACTIVE
}

enum POStatus {
  ACTIVE
  INACTIVE
  PENDING
  CLOSED
}

enum PaymentReceived {
  YES
  NO
}

model Role {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @unique

  remark String?
  status Status  @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username  String   @unique
  password  String
  firstName String
  lastName  String
  email     String   @unique
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  remark    String?
  roleId    String   @db.Uuid
  role      Role     @relation(fields: [roleId], references: [id])
}

model PurchaseOrder {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerPONumber  String
  poAmount          Float
  serviceType       String
  contractDuration  String
  contractType      String
  startFrom         DateTime?
  endDate           DateTime?
  paymentTerms      String
  billingPlan       String
  billingNumber     String?
  customerName      String?
  billDate          DateTime?
  billSubmittedDate DateTime?
  paymentReceived       PaymentReceived @default(NO)
  paymentReceivedDate   DateTime?
  paymentReceivedAmount Float

  status    POStatus @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  remark    String?
}
