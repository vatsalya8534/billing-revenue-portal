generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  ACTIVE
  INACTIVE
}

enum PaymentReceived {
  YES
  NO
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum OrderType {
  AMC
  FMS
  SOFTWARE
  OTHER
}

enum POStatus {
  LIVE
  CLOSED
}

model Role {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique
  remark    String?
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username  String   @unique
  password  String
  firstName String
  lastName  String
  email     String   @unique
  status    Status   @default(ACTIVE)
  remark    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  roleId    String   @db.Uuid
  role      Role     @relation(fields: [roleId], references: [id])
}

model PurchaseOrder {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerPONumber   String
  poAmount           Float
  serviceTypeId      String           @db.Uuid
  contractId         String           @db.Uuid
  startFrom          DateTime?
  endDate            DateTime?
  paymentTerms       String
  customerId         String           @db.Uuid
  billingPlanId      String           @db.Uuid
  poOwner            String
  remark             String?
  status             POStatus         @default(LIVE)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  contractDurationId String           @db.Uuid
  ageingDays         String?
  scope              String
  billingCycles      BillingCycle[]
  billingPlan        BillingPlan      @relation(fields: [billingPlanId], references: [id])
  contractDuration   ContractDuration @relation(fields: [contractDurationId], references: [id])
  contract           ContractType     @relation(fields: [contractId], references: [id])
  customer           Customer         @relation(fields: [customerId], references: [id])
  ServiceType        ServiceType      @relation(fields: [serviceTypeId], references: [id])
}

model BillingCycle {
  id                   String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  billingSubmittedDate DateTime?
  paymentReceived      PaymentReceived @default(NO)
  paymentReceivedDate  DateTime?
  paymentDueDate       DateTime?
  billingRemark        String?
  purchaseOrderId      String          @db.Uuid
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  collectedAmount      Float?
  invoiceAmount        Float?
  invoiceDate          DateTime?
  invoiceNumber        String
  br                   DateTime?
  tds                  String
  purchaseOrder        PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id])
}

model ServiceType {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String          @unique
  remark         String?
  status         Status          @default(ACTIVE)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  purchaseOrders PurchaseOrder[]
}

model BillingPlan {
  id                 String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String          @unique
  totalBillingCycles Int
  remark             String?
  status             Status          @default(ACTIVE)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  purchaseOrders     PurchaseOrder[]
  project            Project[]
}

model ContractDuration {
  id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String          @unique
  totalNumberOfMonths Int
  remark              String?
  status              Status          @default(ACTIVE)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  purchaseOrders      PurchaseOrder[]
}

model ContractType {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String          @unique
  remark         String?
  status         Status          @default(ACTIVE)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  purchaseOrders PurchaseOrder[]
}

model Customer {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerCode   String          @unique
  firstName      String
  lastName       String?
  companyName    String?
  email          String?         @unique
  phone          String
  alternatePhone String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  country        String?
  postalCode     String?
  gstNumber      String?         @unique
  panNumber      String?
  website        String?
  status         Status          @default(ACTIVE)
  remark         String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  purchaseOrders PurchaseOrder[]
}

model Company {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  companyCode    String?       @unique
  email          String?
  phone          String?
  alternatePhone String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  country        String?
  pincode        String?
  gstNumber      String?       @unique
  panNumber      String?
  cinNumber      String?
  status         CompanyStatus @default(ACTIVE)
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  projects Project[]
}

model Project {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId     String    @db.Uuid
  projectName   String
  startDate     DateTime
  endDate       DateTime?
  poValue       Decimal   @db.Decimal(12, 2)
  orderType     OrderType
  resourceCount Int
  billingPlanId String    @db.Uuid
  totalRevenue  Decimal   @default(0) @db.Decimal(12, 2)
  totalCost     Decimal   @default(0) @db.Decimal(12, 2)
  status        Status    @default(ACTIVE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company     Company     @relation(fields: [companyId], references: [id])
  billingPlan BillingPlan @relation(fields: [billingPlanId], references: [id])

  monthlyPLs ProjectMonthlyPL[]
}

model ProjectMonthlyPL {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  projectId String @db.Uuid

  month Int
  year  Int

  billedAmount Decimal @db.Decimal(12, 2)
  otherCost    Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, month, year])
}
